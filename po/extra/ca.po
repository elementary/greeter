#: data/greeter.metainfo.xml.in:107 data/greeter.metainfo.xml.in:163
msgid "New Features:"
msgstr "Característiques noves:"

#: data/greeter.metainfo.xml.in:109
msgid "Add blurred wallpaper as background"
msgstr "Afegiu un fons de pantalla borrós com a fons"

#: data/greeter.metainfo.xml.in:110
msgid "Make Date and Time larger and bolder with softer shadows"
msgstr ""
"Fes que la data i l'hora siguin més grosses i atrevides amb ombres més suaus."

#: data/greeter.metainfo.xml.in:132
msgid "Prevent a potential issue with dialogs that use portals"
msgstr "Evita un possible problema amb els diàlegs que utilitzen portals"

#: data/greeter.metainfo.xml.in:133
msgid "Fix potential issues with incorrect keyboard layout being set"
msgstr ""
"Solució de problemes potencials amb la configuració incorrecta del teclat"

#: data/greeter.metainfo.xml.in:165
msgid "Provide panel background color interface"
msgstr "Proporciona una interfície de color de fons"

#: data/greeter.metainfo.xml.in:176
msgid "Improvements:"
msgstr "Millores:"

#: data/greeter.metainfo.xml.in:178
msgid "Fix a random issue where Greeter does not load correctly on boot"
msgstr ""
"Solució d'un problema aleatori en què Greeter no es carrega correctament a "
"l'arrencada"

